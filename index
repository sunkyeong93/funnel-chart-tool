  try{const u8=new Uint8Array(await file.arrayBuffer());const files=await unzipXlsx(u8);const wb=parseXlsxWorkbook(files);if(!wb.sheets.length)throw new Error("시트 없음");let chosen=null,data=[];for(const s of wb.sheets){const rows=wb.readSheet(s.name)||[];const d=parseTypeSummary(rows);if(d.length>0){chosen=s;data=d;break;}}if(!data.length)throw new Error("유형/단계별 데이터를 찾지 못했습니다");tyData=data;tyRerender();tySetStatus(`✓ ${file.name} → '${chosen.name}' / ${data.length}개 유형`);}
