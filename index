<script>
(function(){
const STAGE_INFO_LD=[{num:1,icon:"①",name:"커머스인입"},{num:2,icon:"②",name:"정보탐색"},{num:3,icon:"③",name:"주문시도"},{num:4,icon:"④",name:"본인인증"},{num:5,icon:"⑤",name:"가입신청완료"}];
const SEED_LD={total:{name:"너겟 전체",overall:[79340,20458,3624,1980,1380],pc:[41844,14140,2405,1607,1198],mo:[37496,6318,1219,373,182]},campaigns:[{name:"너겟 메인",colorKey:"green",overall:[28973,14364,1647,560,214],pc:[17521,9940,826,385,136],mo:[11452,4424,821,175,78]},{name:"너겟 기획전 (82173)",colorKey:"purple",overall:[34081,2206,288,122,47],pc:[15930,1745,194,88,37],mo:[18151,461,94,34,10]}]};
const COLORS_LD={green:{line:"#3CAA78",area:"rgba(60,170,120,0.20)"},purple:{line:"#785FD2",area:"rgba(120,95,210,0.18)"},guide:{line:"#9CA3AF",strokeDash:"4,4"},arrowDark:"#6B7280",arrowLight:"#F3F4F6",axisGrid:"#E5E7EB",axisLabel:"#9CA3AF"};
const DEVICE_COLORS_LD=[{fill:"#A5CDFF",line:"#A5CDFF"},{fill:"#B09CF0",line:"#B09CF0"}];
function arrowPolygon_ld(x,y,w,h){const tipW=h/2;return`${x},${y} ${x+w-tipW},${y} ${x+w},${y+h/2} ${x+w-tipW},${y+h} ${x},${y+h}`;}
function smoothPath_ld(points){if(points.length===0)return"";if(points.length===1)return`M ${points[0][0]},${points[0][1]}`;let d=`M ${points[0][0].toFixed(2)},${points[0][1].toFixed(2)}`;for(let i=0;i<points.length-1;i++){const[x0,y0]=points[i],[x1,y1]=points[i+1],dx=(x1-x0)/2;d+=` C ${(x0+dx).toFixed(2)},${y0.toFixed(2)} ${(x1-dx).toFixed(2)},${y1.toFixed(2)} ${x1.toFixed(2)},${y1.toFixed(2)}`;}return d;}
function drawArrows_ld(out,x0,y0,totalW,h){const N=STAGE_INFO_LD.length,w=totalW/N;for(let i=0;i<N;i++){const x=x0+i*w,isHi=i<2;out.push(`<polygon points="${arrowPolygon_ld(x,y0,w,h)}" fill="${isHi?COLORS_LD.arrowDark:COLORS_LD.arrowLight}"/>`);const cx=x+(w-h/2)/2;out.push(`<text x="${cx.toFixed(2)}" y="${(y0+h/2+7).toFixed(2)}" text-anchor="middle" font-size="20" font-weight="700" fill="${isHi?"#FFFFFF":"#6B7280"}">${esc(STAGE_INFO_LD[i].name)}</text>`);}}
function renderSVG_ld_type(data,opts){
  opts=opts||{};const showGuide=opts.showGuide!==false;const W=1800,H=760,padX=60,arrowsH=60,statsH=80;
  const statsY=arrowsH+20,plotTop=statsY+statsH+16,plotBottom=H-80,plotH=plotBottom-plotTop,totalW=W-padX*2,N=STAGE_INFO_LD.length;
  const xCenter=i=>padX+i*(totalW/N),ys=p=>plotBottom-(p/100)*plotH;
  const totalPcts=data.total.overall.map(v=>pct(v,data.total.overall[0]));
  const campaignPcts=data.campaigns.map(c=>c.overall.map(v=>pct(v,c.overall[0])));
  const out=[];
  out.push(`<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 ${W} ${H}" width="${W}" height="${H}" font-family="-apple-system,BlinkMacSystemFont,'Pretendard','Noto Sans KR',sans-serif">`);
  out.push(`<defs><linearGradient id="grad-cmp1-ld" x1="0" y1="0" x2="0" y2="1"><stop offset="0%" stop-color="${COLORS_LD.green.line}" stop-opacity="0.30"/><stop offset="100%" stop-color="${COLORS_LD.green.line}" stop-opacity="0.02"/></linearGradient><linearGradient id="grad-cmp2-ld" x1="0" y1="0" x2="0" y2="1"><stop offset="0%" stop-color="${COLORS_LD.purple.line}" stop-opacity="0.30"/><stop offset="100%" stop-color="${COLORS_LD.purple.line}" stop-opacity="0.02"/></linearGradient></defs>`);
  out.push(`<rect width="${W}" height="${H}" fill="#ffffff"/>`);
  drawArrows_ld(out,padX,0,totalW,arrowsH);
  for(let i=0;i<data.campaigns.length;i++){const c=data.campaigns[i],col=COLORS_LD[c.colorKey];const boxX=padX+totalW-360-i*380,boxY=statsY,boxW=360,boxH=60;out.push(`<rect x="${boxX}" y="${boxY}" width="${boxW}" height="${boxH}" rx="10" ry="10" fill="${i===0?'rgba(60,170,120,0.10)':'rgba(120,95,210,0.10)'}" stroke="${col.line}" stroke-opacity="0.3" stroke-width="1"/>`);out.push(`<text x="${boxX+boxW/2}" y="${boxY+22}" text-anchor="middle" font-size="14" font-weight="700" fill="${col.line}">${esc(c.name)}</text>`);const inflow=c.overall[0],signup=c.overall[c.overall.length-1],rate=pct(signup,inflow);const tx1=boxX+72,tx2=boxX+192,tx3=boxX+300;out.push(`<text x="${tx1}" y="${boxY+42}" text-anchor="middle" font-size="11" fill="#6B7280">커머스인입</text>`);out.push(`<text x="${tx1}" y="${boxY+56}" text-anchor="middle" font-size="14" font-weight="700" fill="#1F2937">${fmtNum(inflow)}</text>`);out.push(`<text x="${tx2}" y="${boxY+42}" text-anchor="middle" font-size="11" fill="#6B7280">가입신청완료</text>`);out.push(`<text x="${tx2}" y="${boxY+56}" text-anchor="middle" font-size="14" font-weight="700" fill="#1F2937">${fmtNum(signup)}</text>`);out.push(`<text x="${tx3}" y="${boxY+42}" text-anchor="middle" font-size="11" fill="#6B7280">최종전환</text>`);out.push(`<text x="${tx3}" y="${boxY+56}" text-anchor="middle" font-size="14" font-weight="700" fill="${col.line}">${rate.toFixed(2)}%</text>`);}
  for(const p of[0,25,50,75,100]){const y=ys(p);out.push(`<line x1="${padX}" y1="${y.toFixed(2)}" x2="${padX+totalW}" y2="${y.toFixed(2)}" stroke="${COLORS_LD.axisGrid}" stroke-width="1" stroke-dasharray="${p===0?'0':'3,3'}"/>`);out.push(`<text x="${(padX-12).toFixed(2)}" y="${(y+4).toFixed(2)}" text-anchor="end" font-size="12" fill="${COLORS_LD.axisLabel}">${p}%</text>`);}
  const baselineY=ys(0);
  function drawAreaLine(percents,gradId,lineColor,dashed){const points=percents.map((p,i)=>[xCenter(i),ys(p)]);const areaD=`M ${xCenter(0).toFixed(2)},${baselineY.toFixed(2)} L ${xCenter(0).toFixed(2)},${ys(percents[0]).toFixed(2)} `+smoothPath_ld(points).replace(/^M [^ ]+ /,"")+` L ${xCenter(N-1).toFixed(2)},${baselineY.toFixed(2)} Z`;out.push(`<path d="${areaD}" fill="url(#${gradId})"/>`);out.push(`<path d="${smoothPath_ld(points)}" fill="none" stroke="${lineColor}" stroke-width="${dashed?2:2.5}" stroke-linejoin="round" stroke-linecap="round"${dashed?' stroke-dasharray="6,4"':''}/>`);const lastX=xCenter(N-1),lastY=ys(percents[N-1]);out.push(`<line x1="${lastX.toFixed(2)}" y1="${lastY.toFixed(2)}" x2="${(padX+totalW).toFixed(2)}" y2="${lastY.toFixed(2)}" stroke="${lineColor}" stroke-width="${dashed?2:2.5}" stroke-linecap="round"${dashed?' stroke-dasharray="6,4"':''}/>`);}
  if(showGuide){const points=totalPcts.map((p,i)=>[xCenter(i),ys(p)]);out.push(`<path d="${smoothPath_ld(points)}" fill="none" stroke="${COLORS_LD.guide.line}" stroke-width="1.5" stroke-dasharray="${COLORS_LD.guide.strokeDash}" stroke-linejoin="round" stroke-linecap="round"/>`);}
  drawAreaLine(campaignPcts[1],"grad-cmp2-ld",COLORS_LD.purple.line,true);
  drawAreaLine(campaignPcts[0],"grad-cmp1-ld",COLORS_LD.green.line,false);
  function drawMarkersAndLabels(percents,values,colorKey,above){const col=COLORS_LD[colorKey];for(let i=1;i<N;i++){const cx=xCenter(i),cy=ys(percents[i]);out.push(`<circle cx="${cx.toFixed(2)}" cy="${cy.toFixed(2)}" r="6" fill="#FFFFFF" stroke="${col.line}" stroke-width="2.5"/>`);const ly=above?cy-22:cy+30,ly2=above?cy-8:cy+44;out.push(`<text x="${cx.toFixed(2)}" y="${ly.toFixed(2)}" text-anchor="middle" font-size="20" font-weight="800" fill="${col.line}">${percents[i].toFixed(percents[i]<1?2:1)}%</text>`);out.push(`<text x="${cx.toFixed(2)}" y="${ly2.toFixed(2)}" text-anchor="middle" font-size="13" fill="#6B7280">${fmtNum(values[i])}명</text>`);}}
  drawMarkersAndLabels(campaignPcts[0],data.campaigns[0].overall,"green",true);
  drawMarkersAndLabels(campaignPcts[1],data.campaigns[1].overall,"purple",false);
  out.push(`</svg>`);return out.join("\n");
}
function renderSVG_ld_device(data,opts){
  opts=opts||{};const showGuide=opts.showGuide!==false;const W=1800,H=880,panelW=(W-60)/2,panelGap=30;
  const out=[];out.push(`<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 ${W} ${H}" width="${W}" height="${H}" font-family="-apple-system,BlinkMacSystemFont,'Pretendard','Noto Sans KR',sans-serif">`);out.push(`<rect width="${W}" height="${H}" fill="#ffffff"/>`);
  function drawPanel(deviceKey,x0){
    const N=STAGE_INFO_LD.length,plotPadX=56,arrowsRowY=y0+60,arrowsH=36,plotTop=arrowsRowY+arrowsH+24,plotBottom=y0+panelH-40,plotH=plotBottom-plotTop,plotL=x0+plotPadX,plotW=panelW-plotPadX*2,slotW=plotW/N;
    const y0=20,panelH=H-40;const barWidth=slotW*0.42;
    out.push(`<rect x="${x0}" y="${y0}" width="${panelW}" height="${panelH}" rx="14" ry="14" fill="#FFFFFF" stroke="#E5E7EB" stroke-width="1"/>`);
    const devLabel=deviceKey==="pc"?"PC":"MO";out.push(`<rect x="${x0+18}" y="${y0+14}" width="60" height="28" rx="14" ry="14" fill="#F3F4F6" stroke="#E5E7EB"/>`);out.push(`<text x="${x0+48}" y="${y0+33}" text-anchor="middle" font-size="14" font-weight="700" fill="#374151">${devLabel}</text>`);
    for(let i=0;i<N;i++){const sx=plotL+i*slotW,isHi=i<2;out.push(`<polygon points="${arrowPolygon_ld(sx,arrowsRowY,slotW,arrowsH)}" fill="${isHi?COLORS_LD.arrowDark:COLORS_LD.arrowLight}"/>`);out.push(`<text x="${(sx+slotW/2-arrowsH/4).toFixed(2)}" y="${(arrowsRowY+arrowsH/2+5).toFixed(2)}" text-anchor="middle" font-size="13" font-weight="700" fill="${isHi?"#FFFFFF":"#6B7280"}">${esc(STAGE_INFO_LD[i].name)}</text>`);}
    for(const p of[0,25,50,75,100]){const y=plotBottom-(p/100)*plotH;out.push(`<line x1="${plotL}" y1="${y.toFixed(2)}" x2="${plotL+plotW}" y2="${y.toFixed(2)}" stroke="${COLORS_LD.axisGrid}" stroke-width="1" stroke-dasharray="${p===0?'0':'3,3'}"/>`);out.push(`<text x="${(plotL-8).toFixed(2)}" y="${(y+4).toFixed(2)}" text-anchor="end" font-size="11" fill="${COLORS_LD.axisLabel}">${p}%</text>`);}
    function passPct(arr,i){return i===0?100:pct(arr[i],arr[i-1]);}
    function ysP(p){return plotBottom-(p/100)*plotH;}
    for(let i=1;i<N;i++){const sx=plotL+i*slotW,cx=sx+slotW/2;const c1p=passPct(data.campaigns[0][deviceKey],i),c2p=passPct(data.campaigns[1][deviceKey],i);const items=c1p>=c2p?[{pct:c1p,col:DEVICE_COLORS_LD[0]},{pct:c2p,col:DEVICE_COLORS_LD[1]}]:[{pct:c2p,col:DEVICE_COLORS_LD[1]},{pct:c1p,col:DEVICE_COLORS_LD[0]}];for(const it of items){if(it.pct<=0)continue;const by=ysP(it.pct),bh=plotBottom-by;out.push(`<rect x="${(cx-barWidth/2).toFixed(2)}" y="${by.toFixed(2)}" width="${barWidth.toFixed(2)}" height="${Math.max(2,bh).toFixed(2)}" rx="3" ry="3" fill="${it.col.fill}"/>`);}
    out.push(`<text x="${(cx-2).toFixed(2)}" y="${(ysP(c1p)-8).toFixed(2)}" text-anchor="end" font-size="11" font-weight="700" fill="${DEVICE_COLORS_LD[0].line}">${c1p.toFixed(1)}%</text>`);out.push(`<text x="${(cx+4).toFixed(2)}" y="${(ysP(c2p)-8).toFixed(2)}" text-anchor="start" font-size="11" font-weight="700" fill="${DEVICE_COLORS_LD[1].line}">${c2p.toFixed(1)}%</text>`);}
    for(let ci=0;ci<data.campaigns.length;ci++){const arr=data.campaigns[ci][deviceKey],col=DEVICE_COLORS_LD[ci];const linePts=[];for(let i=0;i<N;i++){const cx=plotL+(i+0.5)*slotW;linePts.push([cx,ysP(passPct(arr,i))]);}out.push(`<polyline points="${linePts.map(p=>`${p[0].toFixed(2)},${p[1].toFixed(2)}`).join(" ")}" fill="none" stroke="${col.line}" stroke-width="2" stroke-linejoin="round" stroke-linecap="round"/>`);for(const[x,y]of linePts)out.push(`<circle cx="${x.toFixed(2)}" cy="${y.toFixed(2)}" r="4" fill="#FFFFFF" stroke="${col.line}" stroke-width="2"/>`);}
    if(showGuide){const totalArr=data.total[deviceKey];const linePts=[];for(let i=0;i<N;i++){const cx=plotL+(i+0.5)*slotW;linePts.push([cx,ysP(passPct(totalArr,i))]);}out.push(`<polyline points="${linePts.map(p=>`${p[0].toFixed(2)},${p[1].toFixed(2)}`).join(" ")}" fill="none" stroke="${COLORS_LD.guide.line}" stroke-width="1.5" stroke-dasharray="5,4" stroke-linejoin="round" stroke-linecap="round"/>`);for(const[x,y]of linePts)out.push(`<circle cx="${x.toFixed(2)}" cy="${y.toFixed(2)}" r="3" fill="#FFFFFF" stroke="${COLORS_LD.guide.line}" stroke-width="1.5"/>`);}
  }
  drawPanel("pc",20);drawPanel("mo",20+panelW+panelGap/2);
  out.push(`</svg>`);return out.join("\n");
}
function renderSVG_ld(data,opts){return(opts&&opts.chartType)==="device"?renderSVG_ld_device(data,opts):renderSVG_ld_type(data,opts);}

let ldData=SEED_LD;
const $ldChart=document.getElementById("ld-chart"),$ldChartType=document.getElementById("ld-chartType"),$ldShowGuide=document.getElementById("ld-showGuide"),$ldStatus=document.getElementById("ld-status");
function ldOpts(){return{chartType:$ldChartType.value,showGuide:$ldShowGuide.checked};}
function ldRerender(){$ldChart.innerHTML=renderSVG_ld(ldData,ldOpts());}
function ldSetStatus(msg,kind){$ldStatus.textContent=msg||"";$ldStatus.className="status "+(kind||"ok");}
ldRerender();ldSetStatus(`현재 ${ldData.campaigns.length}개 캠페인 비교 중 (시드 데이터)`);
document.getElementById("ld-reset").addEventListener("click",()=>{ldData=SEED_LD;ldRerender();ldSetStatus("시드 데이터로 복원됨");});
[$ldChartType,$ldShowGuide].forEach(el=>el.addEventListener("change",ldRerender));
document.getElementById("ld-xlsx").addEventListener("change",async(e)=>{
  const file=e.target.files&&e.target.files[0];if(!file)return;
  document.getElementById("ld-fname").textContent=file.name;ldSetStatus(`엑셀 파싱 중: ${file.name}…`);
  try{const u8=new Uint8Array(await file.arrayBuffer());const files=await unzipXlsx(u8);const wb=parseXlsxWorkbook(files);if(!wb.sheets.length)throw new Error("시트 없음");
  function parseLanding(rows){const STEP_RE=/[①②③④⑤]/;function parseBlock(startRow){let firstStep=-1;for(let r=startRow;r<Math.min(rows.length,startRow+12);r++){const v=(rows[r]||[])[1];if(typeof v==="string"&&STEP_RE.test(v)){firstStep=r;break;}}if(firstStep<0)return null;const overall=[],mo=[],pc=[];for(let i=0;i<5;i++){const r=rows[firstStep+i]||[];const o=r[2],m=r[5],p=r[8];if(typeof o!=="number"||typeof m!=="number"||typeof p!=="number")return null;overall.push(o);mo.push(m);pc.push(p);}return{overall,mo,pc,endRow:firstStep+5};}let total=null;const campaigns=[];for(let r=0;r<rows.length;r++){const a=(rows[r]||[])[1];if(typeof a!=="string")continue;const t=a.trim();if(/^\[1\]/.test(t)||/디바이스별.*전체.*너겟/.test(t)){const blk=parseBlock(r+1);if(blk)total={name:"너겟 전체",overall:blk.overall,mo:blk.mo,pc:blk.pc};continue;}const sub=t.match(/^\d\)\s*(.+)/);if(sub){const blk=parseBlock(r+1);if(blk)campaigns.push({name:sub[1].trim(),colorKey:campaigns.length===0?"green":"purple",overall:blk.overall,mo:blk.mo,pc:blk.pc});}}if(!total||campaigns.length<2)return null;return{total,campaigns};}
  let parsed=null;for(const s of wb.sheets){const rows=wb.readSheet(s.name)||[];const r=parseLanding(rows);if(r){parsed={sheet:s.name,data:r};break;}}
  if(!parsed)throw new Error("랜딩별 비교 형식의 데이터를 찾지 못했습니다");
  ldData=parsed.data;ldRerender();ldSetStatus(`✓ ${file.name} → '${parsed.sheet}' / ${parsed.data.campaigns.length}개 캠페인`);}
  catch(err){ldSetStatus("xlsx 파싱 실패: "+err.message,"err");}finally{e.target.value="";}
});
document.getElementById("ld-download").addEventListener("click",()=>{svgDownload(renderSVG_ld(ldData,ldOpts()),$ldChartType.value==="device"?"landing_compare_pc_mo.svg":"landing_compare_type.svg");ldSetStatus("✓ SVG 다운로드 — Figma 캔버스에 드래그하세요");});
})();
</script>
