  <div class="toolbar">
    <button id="ty-download" class="primary">SVG 다운로드</button>
    <label class="inline">차트 타입
      <select id="ty-chartType">
        <option value="combo">막대 + 라인 콤보</option>
        <option value="matrix">포지션 매트릭스 (버블)</option>
      </select>
    </label>
    <label class="inline" id="ty-paletteLabel">팔레트
      <select id="ty-palette">
        <option value="default">기본 (회색·네이비·핑크)</option>
        <option value="grayscale">단색 회색</option>
      </select>
    </label>
