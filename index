</div>

<!-- ════════════════════════════════════════════════════════
     SCRIPTS
═══════════════════════════════════════════════════════════ -->
<script>
// ── TAB SWITCHING ────────────────────────────────────────
document.querySelectorAll('.tab-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
    document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
    btn.classList.add('active');
    document.getElementById(btn.dataset.tab).classList.add('active');
  });
});

// ── SHARED UTILITIES ─────────────────────────────────────
function esc(s) {
  return String(s).replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;").replace(/"/g,"&quot;");
}
function fmtNum(n) { return Math.round(n).toLocaleString(); }
function pct(part, whole) { return whole > 0 ? part / whole * 100 : 0; }
function median(arr) {
  const s = [...arr].sort((a,b)=>a-b); const m = Math.floor(s.length/2);
  return s.length%2 ? s[m] : (s[m-1]+s[m])/2;
}
function niceLogHigh(v) {
  if(v<=0)return 10;const e=Math.floor(Math.log10(v));const m=v/Math.pow(10,e);
  if(m<=1)return Math.pow(10,e);if(m<=2)return 2*Math.pow(10,e);
  if(m<=5)return 5*Math.pow(10,e);return Math.pow(10,e+1);
}
function niceLogTicks(lo,hi) {
  const ticks=[];
  for(let e=Math.floor(Math.log10(lo));e<=Math.ceil(Math.log10(hi));e++){
    for(const m of[1,2,5]){const v=m*Math.pow(10,e);if(v>=lo&&v<=hi)ticks.push(v);}
  }
  if(ticks[0]!==lo)ticks.unshift(lo);
  if(ticks[ticks.length-1]!==hi)ticks.push(hi);
  return Array.from(new Set(ticks)).sort((a,b)=>a-b);
}
function formatNum(n){return n>=1000?n.toLocaleString():String(n);}
function formatK(n){
  if(n>=1000000)return(n/1000000).toFixed(n%1000000===0?0:1)+"M";
  if(n>=1000)return(n/1000).toFixed(0)+"K";return String(n);
}
function niceNumStep(r){
  const e=Math.floor(Math.log10(r));const m=r/Math.pow(10,e);
  let nm;if(m<1.5)nm=1;else if(m<3)nm=2;else if(m<7)nm=5;else nm=10;
  return nm*Math.pow(10,e);
}
const STEP_FIRST=s=>/①/.test(s)||/^1[\.\s]\S/.test(s);
const STEP_LAST=s=>/⑤/.test(s)||/^5[\.\s]\S/.test(s);
const STEP_ANY=s=>/[①②③④⑤]/.test(s)||/^[1-5][\.\s]\S/.test(s);
const ICONS=["①","②","③","④","⑤"];
function isPCDevice(s){return/^pc$/i.test(s)||/desktop/i.test(s);}
function isMODevice(s){return/^mo$|^moweb$|^mobile$|^m$/i.test(s);}
function getRowTotalAfter(row,startCol){
  let last=null;
  for(let c=startCol;c<row.length;c++){
    const v=row[c];if(v==null)continue;
    if(typeof v==="string"){const t=v.trim();if(t===""||t==="-"||t==="–"||t==="N/A")continue;break;}
    if(typeof v==="number"&&isFinite(v))last=v;
  }
  return last;
}
function parseTSVToRows(text){
  const cleaned=String(text).replace(/ /g," ");
  const lines=cleaned.split(/\r?\n/);const rows=[];
  for(const raw of lines){
    if(raw.trim()===""){rows.push([]);continue;}
    let cols;if(raw.includes("\t"))cols=raw.split("\t");else cols=raw.split(/,(?![^"]*"\s*$)/);
    const parsed=cols.map(c=>{
      const t=String(c==null?"":c).trim().replace(/^"|"$/g,"");
      if(t===""||t==="-"||t==="–"||t==="N/A")return null;
      const numStr=t.replace(/,/g,"").replace(/%$/,"");
      if(/^-?\d+(\.\d+)?$/.test(numStr))return parseFloat(numStr);
      return t;
    });
    rows.push(parsed);
  }
  return rows;
}

// ── SHARED XLSX READER ───────────────────────────────────
async function unzipXlsx(u8){
  const dv=new DataView(u8.buffer,u8.byteOffset,u8.byteLength);
  const eocdSig=0x06054b50;let eocd=-1;
  const scanFrom=Math.max(0,u8.length-65557);
  for(let i=u8.length-22;i>=scanFrom;i--){if(dv.getUint32(i,true)===eocdSig){eocd=i;break;}}
  if(eocd<0)throw new Error("올바른 .xlsx 파일이 아닙니다");
  const cdOffset=dv.getUint32(eocd+16,true);const numEntries=dv.getUint16(eocd+10,true);
  const files={};let p=cdOffset;
  for(let i=0;i<numEntries;i++){
    if(dv.getUint32(p,true)!==0x02014b50)break;
    const compMethod=dv.getUint16(p+10,true);const compSize=dv.getUint32(p+20,true);
    const nameLen=dv.getUint16(p+28,true);const extraLen=dv.getUint16(p+30,true);
    const commentLen=dv.getUint16(p+32,true);const lho=dv.getUint32(p+42,true);
    const name=new TextDecoder("utf-8").decode(u8.subarray(p+46,p+46+nameLen));
    p+=46+nameLen+extraLen+commentLen;
    if(dv.getUint32(lho,true)!==0x04034b50)continue;
    const lNameLen=dv.getUint16(lho+26,true);const lExtraLen=dv.getUint16(lho+28,true);
    const dataStart=lho+30+lNameLen+lExtraLen;
    const compData=u8.subarray(dataStart,dataStart+compSize);
    let bytes;
    if(compMethod===0)bytes=compData;
    else if(compMethod===8){
      const stream=new Blob([compData]).stream().pipeThrough(new DecompressionStream("deflate-raw"));
      bytes=new Uint8Array(await new Response(stream).arrayBuffer());
    }else throw new Error("지원하지 않는 압축: "+compMethod);
    files[name]=bytes;
  }
  return files;
}
function parseXlsxWorkbook(files){
  const decoder=new TextDecoder("utf-8");const text=name=>files[name]?decoder.decode(files[name]):null;
  const sharedStrings=[];
  if(files["xl/sharedStrings.xml"]){
    const doc=new DOMParser().parseFromString(text("xl/sharedStrings.xml"),"text/xml");
    for(const si of doc.getElementsByTagName("si")){let str="";for(const t of si.getElementsByTagName("t"))str+=t.textContent||"";sharedStrings.push(str);}
  }
  const rid2target={};
  if(files["xl/_rels/workbook.xml.rels"]){
    const rdoc=new DOMParser().parseFromString(text("xl/_rels/workbook.xml.rels"),"text/xml");
    for(const r of rdoc.getElementsByTagName("Relationship"))rid2target[r.getAttribute("Id")]=r.getAttribute("Target");
  }
  const sheets=[];
  if(files["xl/workbook.xml"]){
    const wdoc=new DOMParser().parseFromString(text("xl/workbook.xml"),"text/xml");
    for(const s of wdoc.getElementsByTagName("sheet")){
      const name=s.getAttribute("name");let rid=s.getAttribute("r:id");
      if(!rid)for(let i=0;i<s.attributes.length;i++){if(s.attributes[i].localName==="id"){rid=s.attributes[i].value;break;}}
      const target=rid2target[rid];if(!target)continue;
      sheets.push({name,file:target.startsWith("/")?target.slice(1):"xl/"+target});
    }
  }
  function colRefToIdx(ref){let n=0;for(const c of ref)n=n*26+(c.charCodeAt(0)-64);return n-1;}
  function readSheet(name){
    const sheet=sheets.find(s=>s.name===name);if(!sheet)return null;
    const xml=text(sheet.file);if(!xml)return null;
    const doc=new DOMParser().parseFromString(xml,"text/xml");const result=[];
    for(const row of doc.getElementsByTagName("row")){
      const rIdx=parseInt(row.getAttribute("r"),10)-1;
      while(result.length<=rIdx)result.push([]);const arr=result[rIdx];
      for(const cell of row.getElementsByTagName("c")){
        const ref=cell.getAttribute("r");const m=ref?ref.match(/^[A-Z]+/):null;if(!m)continue;
        const ci=colRefToIdx(m[0]);const t=cell.getAttribute("t");
        const vEl=cell.getElementsByTagName("v")[0];const isEl=cell.getElementsByTagName("is")[0];
        let val;
        if(t==="s"&&vEl)val=sharedStrings[parseInt(vEl.textContent,10)];
        else if(t==="inlineStr"&&isEl)val=isEl.textContent.trim();
        else if(t==="str"&&vEl)val=vEl.textContent;
        else if(t==="b"&&vEl)val=vEl.textContent==="1";
        else if(vEl)val=parseFloat(vEl.textContent);
        while(arr.length<ci)arr.push(null);arr[ci]=val;
      }
    }
    return result;
  }
  return{sheets,readSheet};
}
function svgDownload(svgStr,filename){
