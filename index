  <details class="data-panel" open>
    <summary>데이터 갱신</summary>
    <div class="body">
      <div class="upload-row">
        <label class="file-btn"><input type="file" id="ld-xlsx" accept=".xlsx" />📂 엑셀 파일 선택 (.xlsx)</label>
