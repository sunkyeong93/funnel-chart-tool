const COLORS_ST={pinkArea:"rgba(232,28,122,0.12)",pinkLine:"#E81C7A",pinkLabel:"#E81C7A",pinkBoxBg:"#FFEAF4",pinkBoxBorder:"#FBC9DD",pinkBoxText:"#E81C7A",pinkArrow:"#E81C7A",greyBoxBg:"#F3F4F6",greyBoxBorder:"#E5E7EB",greyBoxText:"#374151",greyArrow:"#9CA3AF",pcArea:"rgba(60,170,120,0.15)",pcLine:"#3CAA78",pcLabel:"#3CAA78",moArea:"rgba(120,95,210,0.15)",moLine:"#785FD2",moLabel:"#785FD2",axisGrid:"#E5E7EB",axisLabel:"#9CA3AF",valueLabel:"#374151",metaLabel:"#9CA3AF",baseline:"#9CA3AF"};
